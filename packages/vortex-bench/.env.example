# vortex-bench env template. Put real values in shell env (~/.zshrc), not this file.

# --- Provider keys（设任何一个即可自动选用） ---
# 优先级：ZHIPU > ANTHROPIC > MINIMAX
# ZHIPU_API_KEY=...             # 智谱 GLM-4.7 / glm-4.6v（Anthropic-compat）
# ANTHROPIC_API_KEY=...          # Claude Haiku / Sonnet 官方
# MINIMAX_API_KEY=...            # MiniMax M2.7（需普通 sk- key，sk-cp- coding plan 不能直连）

# --- 显式切 provider（覆盖自动选择） ---
# BENCH_PROVIDER=zhipu|anthropic|minimax

# --- 模型 / 端点覆盖（默认已按 provider 合理配置，一般不动） ---
# BENCH_BASE_URL=https://open.bigmodel.cn/api/anthropic
# BENCH_MODEL=glm-4.7

# --- 运行限额 ---
BENCH_MAX_STEPS=30
# BENCH_MAX_TOKENS=200000

# --- vortex-mcp binary 路径（一般不动） ---
# VORTEX_MCP_BIN=../mcp/dist/src/server.js
