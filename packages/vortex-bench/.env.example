# vortex-bench env (copy to .env and fill in)
# .env is gitignored.

# --- Agent LLM (MiniMax by default) ---
# Put MINIMAX_API_KEY in shell env (e.g. ~/.zshrc) instead of here; bench reads from process.env.
# MINIMAX_API_KEY=sk-cp-...

# Anthropic-compatible base URL.
# International: https://api.minimax.io/anthropic
# China:         https://api.minimaxi.com/anthropic
BENCH_BASE_URL=https://api.minimax.io/anthropic

# Model id.
BENCH_MODEL=MiniMax-M2.7

# --- Runtime limits ---
# Hard stops for agent loop (per scenario).
BENCH_MAX_STEPS=30
BENCH_MAX_COST_USD=0.5

# --- vortex-mcp stdio binary ---
# Path to vortex-mcp server binary. Default: workspace-linked.
# VORTEX_MCP_BIN=../mcp/dist/src/server.js
